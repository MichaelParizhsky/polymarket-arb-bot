# =============================================================================
# Bot B — paper trading + live market data (copy into Railway / .env)
# =============================================================================
# - PAPER_TRADING=true → simulated fills only; Polymarket REST/WS still use live books.
# - Unfreeze: PAPER_RESET_RISK_ON_START + PAPER_SKIP_HARD_STOP + PAPER_SKIP_BUDGETS
# - DAILY_CLOSE_ONLY=false → avoids "no markets today" idle loops (common stall cause).
# =============================================================================

BOT_NAME=Bot B

# Core
PAPER_TRADING=true
LOG_LEVEL=INFO

# --- Unfreeze & exploration (paper only) ---
PAPER_RESET_RISK_ON_START=true
PAPER_SKIP_HARD_STOP=true
PAPER_SKIP_BUDGETS=true

# Live feeds (no private Polymarket key required for public orderbooks; keys optional)
USE_WS_ORDERBOOK=true
MARKET_POLL_INTERVAL=5
ORDERBOOK_POLL_INTERVAL=1

# Coverage: multi-day markets + enough names for strategies to find edges
DAILY_CLOSE_ONLY=false
MAX_DAYS_TO_RESOLUTION=30
MAX_MARKETS=500

# Faster paper iteration (still respects min CLOB size inside executor)
MIN_TRADE_INTERVAL=5
TOKEN_COOLDOWN=45

# Strategies: strong mix for research (latency arb stays off — fee-negative on Poly)
STRATEGY_COMBINATORIAL=true
STRATEGY_MARKET_MAKING=true
STRATEGY_RESOLUTION=true
STRATEGY_QUICK_RESOLUTION=true
STRATEGY_CRYPTO_5M=true
STRATEGY_LATENCY_ARB=false
STRATEGY_EVENT_DRIVEN=false
STRATEGY_FUTURES_HEDGE=false
STRATEGY_SWARM=false

# Quick resolution: more frequent re-entry in paper
QUICK_RESOLUTION_ENTERED_HOURS=0.5
QUICK_RESOLUTION_MIN_VOLUME=100
QUICK_RESOLUTION_MAX_SPEND=150

# Optional: Kalshi + cross-exchange / weather (set credentials first)
# KALSHI_ENABLED=true
# STRATEGY_CROSS_EXCHANGE=true
# STRATEGY_WEATHER=false

# Optional: Binance spot feed for crypto strategies (public endpoints often work without keys)
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws
# BINANCE_REST_URL=https://api.binance.com

# Drawdown (ignored for hard-stop when PAPER_SKIP_HARD_STOP=true)
MAX_DRAWDOWN_PCT=0.50
