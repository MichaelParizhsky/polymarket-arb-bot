# Claude AI (for meta-agent strategy analysis)
ANTHROPIC_API_KEY=

# Polymarket
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Binance (read-only, for price feeds)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bot settings
PAPER_TRADING=true
STARTING_BALANCE=10000.0
LOG_LEVEL=INFO

# Risk limits
MAX_POSITION_SIZE=500.0
MAX_TOTAL_EXPOSURE=5000.0
MIN_EDGE_THRESHOLD=0.02
MAX_SLIPPAGE=0.005

# Kalshi (optional - for cross-exchange arb)
KALSHI_ENABLED=false
KALSHI_API_TOKEN=
KALSHI_EMAIL=
KALSHI_PASSWORD=

# Binance futures (optional - for hedging latency arb positions)
BINANCE_FUTURES_ENABLED=false

# Strategy toggles
STRATEGY_REBALANCING=true
STRATEGY_COMBINATORIAL=true
STRATEGY_LATENCY_ARB=true
STRATEGY_MARKET_MAKING=true
STRATEGY_RESOLUTION=true
STRATEGY_EVENT_DRIVEN=true
STRATEGY_CROSS_EXCHANGE=false
STRATEGY_FUTURES_HEDGE=false

# Markets coverage (higher = more opportunities but more API load)
MAX_MARKETS=500

# Use WebSocket orderbook feed (faster, replaces REST polling)
USE_WS_ORDERBOOK=true

# Market making
MM_SPREAD_BPS=50
MM_ORDER_SIZE=100.0
MM_MAX_INVENTORY=500.0

# Polling
MARKET_POLL_INTERVAL=5
ORDERBOOK_POLL_INTERVAL=1
BINANCE_WS_RECONNECT_DELAY=5
