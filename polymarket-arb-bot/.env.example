# ─────────────────────────────────────────────
# Polymarket Arb Bot — Environment Config
# ─────────────────────────────────────────────

# ── Mode ──────────────────────────────────────
# "paper" = simulate only, no real trades
# "live"  = execute real on-chain trades (future)
TRADING_MODE=paper

# ── Polymarket API ────────────────────────────
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── Strategy Toggles ─────────────────────────
ENABLE_REBALANCING=true
ENABLE_COMBINATORIAL=true
ENABLE_LATENCY_ARB=true
ENABLE_MARKET_MAKING=true

# ── Rebalancing Config ────────────────────────
REBALANCING_MIN_PROFIT_PCT=0.003       # 0.3% minimum after fees
REBALANCING_MAX_POSITION_USDC=500

# ── Combinatorial Config ──────────────────────
COMBINATORIAL_MIN_PROFIT_PCT=0.005
COMBINATORIAL_MAX_POSITION_USDC=300
COMBINATORIAL_SIMILARITY_THRESHOLD=0.72

# ── Latency Arb Config ────────────────────────
LATENCY_ARB_PRICE_LAG_THRESHOLD=0.008  # 0.8% lag triggers entry
LATENCY_ARB_MAX_POSITION_USDC=200
LATENCY_ARB_SYMBOLS=BTC,ETH,SOL

# ── Market Making Config ──────────────────────
MM_SPREAD_TARGET=0.004                 # 0.4% target spread
MM_MAX_POSITION_USDC=1000
MM_REBALANCE_THRESHOLD=0.6            # rebalance if inventory skews past 60%

# ── Risk Management ───────────────────────────
MAX_TOTAL_EXPOSURE_USDC=2000
MAX_SINGLE_MARKET_EXPOSURE_PCT=0.10   # 10% of total capital per market
GAS_COST_ESTIMATE_USDC=0.02           # ~$0.02 per Polygon tx
PAPER_STARTING_BALANCE_USDC=10000

# ── Binance Price Feed (for latency arb) ─────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
DASHBOARD_REFRESH_SECONDS=5
